<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <import type="android.view.View" />

        <import type="android.graphics.Typeface" />

        <import type="android.graphics.Bitmap" />

        <import type="android.graphics.RenderEffect" />

        <import type="android.graphics.ColorFilter" />

        <variable
            name="backgroundBitmap"
            type="Bitmap" />

        <variable
            name="backgroundResource"
            type="Integer" />

        <variable
            name="blurEffect"
            type="RenderEffect" />

        <variable
            name="colorFilter"
            type="ColorFilter" />

        <variable
            name="gaugeAlpha"
            type="Float" />

        <variable
            name="title"
            type="String" />

        <variable
            name="status"
            type="Integer" />

        <variable
            name="showBtns"
            type="Boolean" />

        <variable
            name="font"
            type="Typeface" />

        <variable
            name="largeCenter"
            type="Boolean" />

        <variable
            name="showChart"
            type="Boolean" />

        <variable
            name="minMaxBelow"
            type="Boolean" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutDashboard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:layout_margin="0dp">

        <ImageView
            android:id="@+id/bgImageView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:elevation="0dp"
            android:scaleType="centerCrop"
            app:bitmap="@{backgroundBitmap}"
            app:colorFilter="@{colorFilter}"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:renderEffect="@{blurEffect}"
            app:resource="@{backgroundResource}" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/headers_wrap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:elevation="1dp"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/con_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:background="@color/transparentBlack"
                android:padding="5dp"
                android:text='@{status == 0 ? "" : context.getString(status)}'
                android:textAlignment="center"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:typeface="@{font}"
                android:visibility="@{status == 0 ? View.INVISIBLE : View.VISIBLE}"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/textTitle"
                android:layout_width="500dp"
                android:layout_height="0dp"
                android:ellipsize="marquee"
                android:maxLines="1"
                android:text="@{title}"
                android:textAlignment="center"
                android:textColor="@android:color/white"
                android:textSize="30sp"
                android:typeface="@{font}"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/con_status" />

            <ImageButton
                android:id="@+id/chartBtn"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginStart="15dp"
                android:background="@android:color/transparent"
                android:scaleType="centerCrop"
                android:src="@drawable/chart"
                android:visibility="@{showBtns ? View.VISIBLE : View.GONE}"
                app:layout_constraintBottom_toBottomOf="@+id/textTitle"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/textTitle" />

            <ImageButton
                android:id="@+id/prevButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/item_details_go_back"
                android:scaleType="centerCrop"
                android:src="@drawable/arrow_back"
                android:visibility="@{showBtns ? View.VISIBLE : View.GONE}"
                app:layout_constraintBottom_toBottomOf="@+id/textTitle"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintEnd_toStartOf="@id/nextBtn"
                app:layout_constraintTop_toTopOf="@+id/textTitle" />

            <ImageButton
                android:id="@+id/nextBtn"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginEnd="30dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/item_details_go_back"
                android:nextFocusForward="@id/include_wrap"
                android:scaleType="centerCrop"
                android:src="@drawable/arrow_forward"
                android:textAlignment="center"
                android:visibility="@{showBtns ? View.VISIBLE : View.GONE}"
                app:layout_constraintBottom_toBottomOf="@+id/textTitle"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/textTitle" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <RelativeLayout
            android:id="@+id/include_wrap"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_centerVertical="true"
            android:layout_marginTop="@{showChart ? 15 : 0}"
            android:clipChildren="false"
            android:elevation="1dp"
            android:gravity="center_vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/headers_wrap">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/dashContent"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.fragment.app.FragmentContainerView
                    android:id="@+id/chartFrag"
                    android:name="com.aatorque.stats.TorqueChart"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout="@layout/fragment_chart"
                    android:visibility="@{showChart ? View.VISIBLE : View.GONE}"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/performanceLayout"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="@{showChart ? View.GONE : View.VISIBLE}"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/splitGuide"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        app:layout_constraintGuide_percent="0.64" />

                    <LinearLayout
                        android:id="@+id/leftPanel"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="2dp"
                        android:orientation="vertical"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/splitGuide"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:orientation="horizontal">

                            <androidx.fragment.app.FragmentContainerView
                                android:id="@+id/gauge1"
                                android:name="com.aatorque.stats.TorqueGauge"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout="@layout/fragment_gauge"
                                android:layout_margin="2dp"
                                android:layout_weight="1"
                                app:alpha="@{gaugeAlpha}" />

                            <androidx.fragment.app.FragmentContainerView
                                android:id="@+id/gauge2"
                                android:name="com.aatorque.stats.TorqueGauge"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout="@layout/fragment_gauge"
                                android:layout_margin="2dp"
                                android:layout_weight="1"
                                app:alpha="@{gaugeAlpha}" />

                            <androidx.fragment.app.FragmentContainerView
                                android:id="@+id/gauge3"
                                android:name="com.aatorque.stats.TorqueGauge"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout="@layout/fragment_gauge"
                                android:layout_margin="2dp"
                                android:layout_weight="1"
                                app:alpha="@{gaugeAlpha}" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:orientation="horizontal">

                            <androidx.fragment.app.FragmentContainerView
                                android:id="@+id/gauge4"
                                android:name="com.aatorque.stats.TorqueGauge"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout="@layout/fragment_gauge"
                                android:layout_margin="2dp"
                                android:layout_weight="1"
                                app:alpha="@{gaugeAlpha}" />

                            <androidx.fragment.app.FragmentContainerView
                                android:id="@+id/gauge5"
                                android:name="com.aatorque.stats.TorqueGauge"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout="@layout/fragment_gauge"
                                android:layout_margin="2dp"
                                android:layout_weight="1"
                                app:alpha="@{gaugeAlpha}" />

                            <androidx.fragment.app.FragmentContainerView
                                android:id="@+id/gauge6"
                                android:name="com.aatorque.stats.TorqueGauge"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout="@layout/fragment_gauge"
                                android:layout_margin="2dp"
                                android:layout_weight="1"
                                app:alpha="@{gaugeAlpha}" />
                        </LinearLayout>

                    </LinearLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/rightPanel"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="2dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/splitGuide"
                        app:layout_constraintTop_toTopOf="parent">

                        <androidx.constraintlayout.widget.Guideline
                            android:id="@+id/rightMidVertical"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            app:layout_constraintGuide_percent="0.5" />

                        <androidx.constraintlayout.widget.Guideline
                            android:id="@+id/rightMidHorizontal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            app:layout_constraintGuide_percent="0.5" />

                        <androidx.constraintlayout.widget.Guideline
                            android:id="@+id/carLeftGuide"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            app:layout_constraintGuide_percent="0.32" />

                        <androidx.constraintlayout.widget.Guideline
                            android:id="@+id/carRightGuide"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            app:layout_constraintGuide_percent="0.68" />

                        <ImageView
                            android:id="@+id/carOutline"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:alpha="0.9"
                            android:layout_marginTop="20dp"
                            android:layout_marginBottom="20dp"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_car_topdown"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="@id/carRightGuide"
                            app:layout_constraintStart_toStartOf="@id/carLeftGuide"
                            app:layout_constraintTop_toTopOf="parent" />

                        <LinearLayout
                            android:id="@+id/cornerFL"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_margin="2dp"
                            android:orientation="vertical"
                            app:layout_constraintBottom_toTopOf="@id/rightMidHorizontal"
                            app:layout_constraintEnd_toStartOf="@id/rightMidVertical"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <androidx.fragment.app.FragmentContainerView
                                android:id="@+id/gauge7"
                                android:name="com.aatorque.stats.TorqueGauge"
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout="@layout/fragment_gauge"
                                android:layout_weight="1"
                                app:alpha="@{gaugeAlpha}" />

                            <androidx.fragment.app.FragmentContainerView
                                android:id="@+id/display1"
                                android:name="com.aatorque.stats.TorqueDisplay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout="@layout/fragment_display"
                                android:layout_gravity="center_horizontal" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/cornerFR"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_margin="2dp"
                            android:orientation="vertical"
                            app:layout_constraintBottom_toTopOf="@id/rightMidHorizontal"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@id/rightMidVertical"
                            app:layout_constraintTop_toTopOf="parent">

                            <androidx.fragment.app.FragmentContainerView
                                android:id="@+id/gauge8"
                                android:name="com.aatorque.stats.TorqueGauge"
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout="@layout/fragment_gauge"
                                android:layout_weight="1"
                                app:alpha="@{gaugeAlpha}" />

                            <androidx.fragment.app.FragmentContainerView
                                android:id="@+id/display2"
                                android:name="com.aatorque.stats.TorqueDisplay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout="@layout/fragment_display"
                                android:layout_gravity="center_horizontal" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/cornerRL"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_margin="2dp"
                            android:orientation="vertical"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/rightMidVertical"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/rightMidHorizontal">

                            <androidx.fragment.app.FragmentContainerView
                                android:id="@+id/gauge9"
                                android:name="com.aatorque.stats.TorqueGauge"
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout="@layout/fragment_gauge"
                                android:layout_weight="1"
                                app:alpha="@{gaugeAlpha}" />

                            <androidx.fragment.app.FragmentContainerView
                                android:id="@+id/display3"
                                android:name="com.aatorque.stats.TorqueDisplay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout="@layout/fragment_display"
                                android:layout_gravity="center_horizontal" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/cornerRR"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_margin="2dp"
                            android:orientation="vertical"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@id/rightMidVertical"
                            app:layout_constraintTop_toBottomOf="@id/rightMidHorizontal">

                            <androidx.fragment.app.FragmentContainerView
                                android:id="@+id/gauge10"
                                android:name="com.aatorque.stats.TorqueGauge"
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout="@layout/fragment_gauge"
                                android:layout_weight="1"
                                app:alpha="@{gaugeAlpha}" />

                            <androidx.fragment.app.FragmentContainerView
                                android:id="@+id/display4"
                                android:name="com.aatorque.stats.TorqueDisplay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout="@layout/fragment_display"
                                android:layout_gravity="center_horizontal" />
                        </LinearLayout>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </RelativeLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
