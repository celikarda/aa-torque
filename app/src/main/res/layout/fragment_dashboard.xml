<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <import type="android.graphics.Bitmap" />
        <import type="android.graphics.ColorFilter" />
        <import type="android.graphics.RenderEffect" />
        <import type="android.graphics.Typeface" />
        <import type="android.view.View" />

        <variable
            name="backgroundBitmap"
            type="Bitmap" />

        <variable
            name="backgroundResource"
            type="Integer" />

        <variable
            name="blurEffect"
            type="RenderEffect" />

        <variable
            name="colorFilter"
            type="ColorFilter" />

        <variable
            name="gaugeAlpha"
            type="Float" />

        <variable
            name="title"
            type="String" />

        <variable
            name="status"
            type="Integer" />

        <variable
            name="showBtns"
            type="Boolean" />

        <variable
            name="font"
            type="Typeface" />

        <variable
            name="largeCenter"
            type="Boolean" />

        <variable
            name="showChart"
            type="Boolean" />

        <variable
            name="minMaxBelow"
            type="Boolean" />

        <variable
            name="denseStyle"
            type="Boolean" />

        <variable
            name="grStyle"
            type="Boolean" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutDashboard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false">

        <ImageView
            android:id="@+id/bgImageView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:scaleType="centerCrop"
            app:bitmap="@{backgroundBitmap}"
            app:colorFilter="@{colorFilter}"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:renderEffect="@{blurEffect}"
            app:resource="@{backgroundResource}" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/headers_wrap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:elevation="1dp"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/con_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/transparentBlack"
                android:padding="5dp"
                android:text='@{status == 0 ? "" : context.getString(status)}'
                android:textAlignment="center"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:typeface="@{font}"
                android:visibility="@{status == 0 ? View.GONE : View.VISIBLE}"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/textTitle"
                android:layout_width="500dp"
                android:layout_height="wrap_content"
                android:ellipsize="marquee"
                android:maxLines="1"
                android:text="@{title}"
                android:textAlignment="center"
                android:textColor="@android:color/white"
                android:textSize="30sp"
                android:typeface="@{font}"
                android:visibility="@{denseStyle || grStyle ? View.GONE : View.VISIBLE}"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/con_status" />

            <ImageButton
                android:id="@+id/chartBtn"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginStart="12dp"
                android:background="@android:color/transparent"
                android:scaleType="centerCrop"
                android:src="@drawable/chart"
                android:visibility="@{showBtns ? View.VISIBLE : View.GONE}"
                app:layout_constraintBottom_toBottomOf="@id/textTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/textTitle" />

            <ImageButton
                android:id="@+id/prevButton"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/item_details_go_back"
                android:scaleType="centerCrop"
                android:src="@drawable/arrow_back"
                android:visibility="@{showBtns ? View.VISIBLE : View.GONE}"
                app:layout_constraintBottom_toBottomOf="@id/textTitle"
                app:layout_constraintEnd_toStartOf="@id/nextBtn"
                app:layout_constraintTop_toTopOf="@id/textTitle" />

            <ImageButton
                android:id="@+id/nextBtn"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginEnd="20dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/item_details_go_back"
                android:nextFocusForward="@id/include_wrap"
                android:scaleType="centerCrop"
                android:src="@drawable/arrow_forward"
                android:visibility="@{showBtns ? View.VISIBLE : View.GONE}"
                app:layout_constraintBottom_toBottomOf="@id/textTitle"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/textTitle" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <RelativeLayout
            android:id="@+id/include_wrap"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:clipChildren="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/headers_wrap">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/dashContent"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.fragment.app.FragmentContainerView
                    android:id="@+id/chartFrag"
                    android:name="com.aatorque.stats.TorqueChart"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout="@layout/fragment_chart"
                    android:visibility="@{showChart ? View.VISIBLE : View.GONE}"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/classicLayout"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="@{!showChart &amp;&amp; !denseStyle &amp;&amp; !grStyle ? View.VISIBLE : View.GONE}"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/classicSplit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        app:layout_constraintGuide_percent="0.76" />

                    <LinearLayout
                        android:id="@+id/classicGauges"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:orientation="horizontal"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/classicSplit"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <androidx.fragment.app.FragmentContainerView
                            android:id="@+id/classicGauge1"
                            android:name="com.aatorque.stats.TorqueGauge"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout="@layout/fragment_gauge"
                            android:layout_margin="2dp"
                            android:layout_weight="1"
                            app:alpha="@{gaugeAlpha}" />

                        <androidx.fragment.app.FragmentContainerView
                            android:id="@+id/classicGauge2"
                            android:name="com.aatorque.stats.TorqueGauge"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout="@layout/fragment_gauge"
                            android:layout_margin="2dp"
                            android:layout_weight="1"
                            app:alpha="@{gaugeAlpha}" />

                        <androidx.fragment.app.FragmentContainerView
                            android:id="@+id/classicGauge3"
                            android:name="com.aatorque.stats.TorqueGauge"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout="@layout/fragment_gauge"
                            android:layout_margin="2dp"
                            android:layout_weight="1"
                            app:alpha="@{gaugeAlpha}" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/classicDisplays"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:gravity="center"
                        android:orientation="vertical"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/classicSplit"
                        app:layout_constraintTop_toTopOf="parent">

                        <androidx.fragment.app.FragmentContainerView
                            android:id="@+id/classicDisplay1"
                            android:name="com.aatorque.stats.TorqueDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:layout="@layout/fragment_display" />

                        <androidx.fragment.app.FragmentContainerView
                            android:id="@+id/classicDisplay2"
                            android:name="com.aatorque.stats.TorqueDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:layout="@layout/fragment_display" />

                        <androidx.fragment.app.FragmentContainerView
                            android:id="@+id/classicDisplay3"
                            android:name="com.aatorque.stats.TorqueDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:layout="@layout/fragment_display" />

                        <androidx.fragment.app.FragmentContainerView
                            android:id="@+id/classicDisplay4"
                            android:name="com.aatorque.stats.TorqueDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:layout="@layout/fragment_display" />
                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/denseLayout"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="@{!showChart &amp;&amp; denseStyle ? View.VISIBLE : View.GONE}"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/denseSplit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        app:layout_constraintGuide_percent="0.62" />

                    <LinearLayout
                        android:id="@+id/leftPanel"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_margin="2dp"
                        android:orientation="vertical"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/denseSplit"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:orientation="horizontal">

                            <androidx.fragment.app.FragmentContainerView
                                android:id="@+id/gauge1"
                                android:name="com.aatorque.stats.MiniTorqueGauge"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout="@layout/fragment_mini_gauge"
                                android:layout_margin="2dp"
                                android:layout_weight="1"
                                app:alpha="@{gaugeAlpha}" />

                            <androidx.fragment.app.FragmentContainerView
                                android:id="@+id/gauge2"
                                android:name="com.aatorque.stats.MiniTorqueGauge"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout="@layout/fragment_mini_gauge"
                                android:layout_margin="2dp"
                                android:layout_weight="1"
                                app:alpha="@{gaugeAlpha}" />

                            <androidx.fragment.app.FragmentContainerView
                                android:id="@+id/gauge3"
                                android:name="com.aatorque.stats.MiniTorqueGauge"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout="@layout/fragment_mini_gauge"
                                android:layout_margin="2dp"
                                android:layout_weight="1"
                                app:alpha="@{gaugeAlpha}" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:orientation="horizontal">

                            <androidx.fragment.app.FragmentContainerView
                                android:id="@+id/gauge4"
                                android:name="com.aatorque.stats.MiniTorqueGauge"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout="@layout/fragment_mini_gauge"
                                android:layout_margin="2dp"
                                android:layout_weight="1"
                                app:alpha="@{gaugeAlpha}" />

                            <androidx.fragment.app.FragmentContainerView
                                android:id="@+id/gauge5"
                                android:name="com.aatorque.stats.MiniTorqueGauge"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout="@layout/fragment_mini_gauge"
                                android:layout_margin="2dp"
                                android:layout_weight="1"
                                app:alpha="@{gaugeAlpha}" />

                            <androidx.fragment.app.FragmentContainerView
                                android:id="@+id/gauge6"
                                android:name="com.aatorque.stats.MiniTorqueGauge"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout="@layout/fragment_mini_gauge"
                                android:layout_margin="2dp"
                                android:layout_weight="1"
                                app:alpha="@{gaugeAlpha}" />
                        </LinearLayout>

                    </LinearLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/rightPanel"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_margin="2dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/denseSplit"
                        app:layout_constraintTop_toTopOf="parent">

                        <androidx.constraintlayout.widget.Guideline
                            android:id="@+id/rightMidVertical"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            app:layout_constraintGuide_percent="0.5" />

                        <androidx.constraintlayout.widget.Guideline
                            android:id="@+id/rightMidHorizontal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            app:layout_constraintGuide_percent="0.5" />

                        <ImageView
                            android:id="@+id/carOutline"
                            android:layout_width="96dp"
                            android:layout_height="0dp"
                            android:layout_marginTop="26dp"
                            android:layout_marginBottom="26dp"
                            android:alpha="0.95"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_car_topdown"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <LinearLayout
                            android:id="@+id/cornerFL"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:gravity="start|center_vertical"
                            android:orientation="vertical"
                            android:paddingStart="8dp"
                            app:layout_constraintBottom_toTopOf="@id/rightMidHorizontal"
                            app:layout_constraintEnd_toStartOf="@id/rightMidVertical"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <androidx.fragment.app.FragmentContainerView
                                android:id="@+id/display1"
                                android:name="com.aatorque.stats.TyreValueDisplay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="2dp"
                                android:layout="@layout/fragment_tyre_value" />

                            <androidx.fragment.app.FragmentContainerView
                                android:id="@+id/display2"
                                android:name="com.aatorque.stats.TyreValueDisplay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout="@layout/fragment_tyre_value" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/cornerFR"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:gravity="end|center_vertical"
                            android:orientation="vertical"
                            android:paddingEnd="8dp"
                            app:layout_constraintBottom_toTopOf="@id/rightMidHorizontal"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@id/rightMidVertical"
                            app:layout_constraintTop_toTopOf="parent">

                            <androidx.fragment.app.FragmentContainerView
                                android:id="@+id/display3"
                                android:name="com.aatorque.stats.TyreValueDisplay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="2dp"
                                android:layout="@layout/fragment_tyre_value" />

                            <androidx.fragment.app.FragmentContainerView
                                android:id="@+id/display4"
                                android:name="com.aatorque.stats.TyreValueDisplay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout="@layout/fragment_tyre_value" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/cornerRL"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:gravity="start|center_vertical"
                            android:orientation="vertical"
                            android:paddingStart="8dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/rightMidVertical"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/rightMidHorizontal">

                            <androidx.fragment.app.FragmentContainerView
                                android:id="@+id/display5"
                                android:name="com.aatorque.stats.TyreValueDisplay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="2dp"
                                android:layout="@layout/fragment_tyre_value" />

                            <androidx.fragment.app.FragmentContainerView
                                android:id="@+id/display6"
                                android:name="com.aatorque.stats.TyreValueDisplay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout="@layout/fragment_tyre_value" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/cornerRR"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:gravity="end|center_vertical"
                            android:orientation="vertical"
                            android:paddingEnd="8dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@id/rightMidVertical"
                            app:layout_constraintTop_toBottomOf="@id/rightMidHorizontal">

                            <androidx.fragment.app.FragmentContainerView
                                android:id="@+id/display7"
                                android:name="com.aatorque.stats.TyreValueDisplay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="2dp"
                                android:layout="@layout/fragment_tyre_value" />

                            <androidx.fragment.app.FragmentContainerView
                                android:id="@+id/display8"
                                android:name="com.aatorque.stats.TyreValueDisplay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout="@layout/fragment_tyre_value" />
                        </LinearLayout>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/grLayout"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="@{!showChart &amp;&amp; grStyle ? View.VISIBLE : View.GONE}"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/grLeftSplit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        app:layout_constraintGuide_percent="0.297" />

                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/grRightSplit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        app:layout_constraintGuide_percent="0.703" />

                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/grMidHorizontal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        app:layout_constraintGuide_percent="0.5" />

                    <androidx.fragment.app.FragmentContainerView
                        android:id="@+id/grGauge1"
                        android:name="com.aatorque.stats.GrTorqueGauge"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout="@layout/fragment_gr_gauge"
                        android:layout_marginStart="6dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginEnd="6dp"
                        android:layout_marginBottom="6dp"
                        app:alpha="@{gaugeAlpha}"
                        app:layout_constraintBottom_toTopOf="@id/grMidHorizontal"
                        app:layout_constraintDimensionRatio="1:1"
                        app:layout_constraintEnd_toStartOf="@id/grLeftSplit"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <androidx.fragment.app.FragmentContainerView
                        android:id="@+id/grGauge2"
                        android:name="com.aatorque.stats.GrTorqueGauge"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout="@layout/fragment_gr_gauge"
                        android:layout_marginStart="6dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginEnd="6dp"
                        android:layout_marginBottom="6dp"
                        app:alpha="@{gaugeAlpha}"
                        app:layout_constraintBottom_toTopOf="@id/grMidHorizontal"
                        app:layout_constraintDimensionRatio="1:1"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/grRightSplit"
                        app:layout_constraintTop_toTopOf="parent" />

                    <androidx.fragment.app.FragmentContainerView
                        android:id="@+id/grGauge3"
                        android:name="com.aatorque.stats.GrTorqueGauge"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout="@layout/fragment_gr_gauge"
                        android:layout_marginStart="6dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginEnd="6dp"
                        android:layout_marginBottom="6dp"
                        app:alpha="@{gaugeAlpha}"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintDimensionRatio="1:1"
                        app:layout_constraintEnd_toStartOf="@id/grLeftSplit"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/grMidHorizontal" />

                    <androidx.fragment.app.FragmentContainerView
                        android:id="@+id/grGauge4"
                        android:name="com.aatorque.stats.GrTorqueGauge"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout="@layout/fragment_gr_gauge"
                        android:layout_marginStart="6dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginEnd="6dp"
                        android:layout_marginBottom="6dp"
                        app:alpha="@{gaugeAlpha}"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintDimensionRatio="1:1"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/grRightSplit"
                        app:layout_constraintTop_toBottomOf="@id/grMidHorizontal" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/grCenterPanel"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/grRightSplit"
                        app:layout_constraintStart_toEndOf="@id/grLeftSplit"
                        app:layout_constraintTop_toTopOf="parent">

                        <LinearLayout
                            android:id="@+id/grTyreInfo"
                            android:layout_width="300dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
